{
	"name": "@eslint-sets/eslint-config",
	"description": "Modern ESLint config with flat config support for Vue, React, Svelte, TypeScript, Next.js, Nuxt, Astro, Angular, UnoCSS and more",
	"type": "module",
	"version": "6.5.0",
	"packageManager": "pnpm@9.15.9",
	"bin": {
		"eslint-sets": "./dist/cli/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./cli": {
			"types": "./dist/cli/index.d.ts",
			"import": "./dist/cli/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"README.md",
		"dist"
	],
	"scripts": {
		"build": "jiti scripts/build.ts",
		"dev": "jiti scripts/build.ts && tsc --watch",
		"gen": "jiti scripts/typegen.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"inspector": "@eslint/config-inspector",
		"prepublishOnly": "pnpm build",
		"release": "bumpp && pnpm publish",
		"validate:examples": "jiti scripts/validate-examples.ts",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@eslint/js": "^9.39.5",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"@vitest/eslint-plugin": "^1.6.23",
		"eslint-config-prettier": "^10.1.8",
		"eslint-flat-config-utils": "^3.2.0",
		"eslint-merge-processors": "^2.0.0",
		"eslint-plugin-import-lite": "^0.6.0",
		"eslint-plugin-jsdoc": "^61.7.1",
		"eslint-plugin-jsonc": "^2.21.1",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-no-only-tests": "^3.4.0",
		"eslint-plugin-perfectionist": "^4.15.1",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-regexp": "^2.10.0",
		"eslint-plugin-solid": "^0.14.5",
		"eslint-plugin-toml": "^1.4.0",
		"eslint-plugin-unicorn": "^56.0.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"eslint-plugin-vue": "^9.33.0",
		"eslint-plugin-yml": "^1.19.1",
		"globals": "^17.7.0",
		"jsonc-eslint-parser": "^2.4.2",
		"local-pkg": "^1.2.1",
		"toml-eslint-parser": "^1.0.3",
		"vue-eslint-parser": "^10.4.1",
		"yaml-eslint-parser": "^1.3.2"
	},
	"devDependencies": {
		"@types/node": "^22.20.1",
		"@vitest/coverage-v8": "^4.1.10",
		"bumpp": "^10.4.1",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.5",
		"eslint-typegen": "^2.3.1",
		"jiti": "^2.7.0",
		"prettier": "^3.9.5",
		"typescript": "~5.9.3",
		"vite": "^8.1.4",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"eslint": "^9.10.0 || ^9.22.0",
		"prettier": "^3.5.3",
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"prettier": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"optionalDependencies": {
		"@angular-eslint/eslint-plugin": "^21.4.0",
		"@angular-eslint/eslint-plugin-template": "^21.4.0",
		"@angular-eslint/template-parser": "^21.4.0",
		"@e18e/eslint-plugin": "^0.5.1",
		"@eslint-react/eslint-plugin": "^1.53.1",
		"@eslint/markdown": "^6.6.0",
		"@next/eslint-plugin-next": ">=15.5.20",
		"@unocss/eslint-plugin": ">=0.65.4",
		"@vue/compiler-sfc": "^3.5.39",
		"astro-eslint-parser": "^1.4.0",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-command": "^3.5.2",
		"eslint-plugin-erasable-syntax-only": "^0.4.2",
		"eslint-plugin-format": "^0.1.3",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-pnpm": "^1.6.1",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-hooks-extra": "^2.13.0",
		"eslint-plugin-react-refresh": "^0.5.3",
		"eslint-plugin-svelte": "^2.46.1",
		"eslint-plugin-vuejs-accessibility": "^2.5.0",
		"eslint-processor-vue-blocks": "^2.0.0",
		"svelte": "^5.56.4",
		"svelte-eslint-parser": "^1.8.0"
	},
	"engines": {
		"node": "^18.18.0 || ^20.9.0 || >=21.1.0"
	},
	"keywords": [
		"eslint",
		"eslint-config",
		"eslint-flat-config",
		"vue",
		"react",
		"svelte",
		"typescript",
		"nextjs",
		"nuxt",
		"astro",
		"angular",
		"solid",
		"unocss",
		"accessibility",
		"a11y",
		"cli"
	],
	"license": "MIT",
	"author": "saqqdy <https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/eslint-sets#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/eslint-sets/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/eslint-sets.git"
	}
}
